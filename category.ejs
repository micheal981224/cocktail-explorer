
<% title = category %>
<%- include('partials/header') %>

<div class="container page-pad">

  <div class="search-header">
    <h2><span class="text-gold"><%= category %></span></h2>
    <% if (drinks.length > 0) { %>
      <p>Showing <%= drinks.length %> recipes</p>
    <% } %>
  </div>

  <% if (error) { %>
    <p class="error-msg"><%= error %></p>
  <% } %>

  <% if (drinks.length === 0 && !error) { %>
    <div class="no-results">
      <div class="big-icon">🫙</div>
      <p>Nothing found in this category yet.</p>
    </div>
  <% } %>

  <% if (drinks.length > 0) { %>
    <div class="cocktail-grid">
      <% drinks.forEach(drink => { %>
        <a class="cocktail-card" href="/cocktail/<%= drink.idDrink %>">
          <div class="card-img">
            <img src="<%= drink.strDrinkThumb %>" alt="<%= drink.strDrink %>" loading="lazy" />
          </div>
          <div class="card-body">
            <p class="card-category"><%= drink.strGlass || '' %></p>
            <h3 class="card-name"><%= drink.strDrink %></h3>
            <p class="card-ingredients">
              <%= drink.ingredients.map(i => i.ingredient).join(', ') %>
            </p>
            <span class="card-link">View Recipe</span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
